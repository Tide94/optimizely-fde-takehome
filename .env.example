# Reddit uses the public unauthenticated JSON API — no client ID needed.
# This User-Agent is optional (a sensible default is used if unset),
# but Reddit asks every caller to identify itself.
REDDIT_USER_AGENT=voc_review_fetcher/0.1.0 by u/yourusername

# Required for G2. Sign up at https://www.scrapingbee.com (free tier = 1000 credits).
SCRAPINGBEE_API_KEY=your_scrapingbee_key
